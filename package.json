{
  "name": "hono-multi-db-api",
  "version": "1.0.0",
  "description": "Production-ready Hello World API with multi-database support (MySQL, MongoDB, SQLite)",
  "type": "module",
  "scripts": {
    "migrate:dev": "SERVICE_NAME=cli bun run --env-file=.env.dev scripts/migrate.ts up",
    "migrate:dev:down": "SERVICE_NAME=cli bun run --env-file=.env.dev scripts/migrate.ts down",
    "migrate:dev:mysql": "SERVICE_NAME=cli bun run --env-file=.env.dev scripts/migrate.ts up mysql",
    "migrate:dev:mongo": "SERVICE_NAME=cli bun run --env-file=.env.dev scripts/migrate.ts up mongo",
    "migrate:dev:sqlite": "SERVICE_NAME=cli bun run --env-file=.env.dev scripts/migrate.ts up sqlite",
    "migrate:dev:pg": "SERVICE_NAME=cli bun run --env-file=.env.dev scripts/migrate.ts up pg",
    "migrate:prod": "SERVICE_NAME=cli bun run --env-file=.env.prod scripts/migrate.ts up",
    "migrate:prod:mysql": "SERVICE_NAME=cli bun run --env-file=.env.prod scripts/migrate.ts up mysql",
    "migrate:prod:mongo": "SERVICE_NAME=cli bun run --env-file=.env.prod scripts/migrate.ts up mongo",
    "migrate:prod:sqlite": "SERVICE_NAME=cli bun run --env-file=.env.prod scripts/migrate.ts up sqlite",
    "migrate:prod:pg": "SERVICE_NAME=cli bun run --env-file=.env.prod scripts/migrate.ts up pg",
    "seed:dev": "SERVICE_NAME=cli bun run --env-file=.env.dev scripts/seed.ts",
    "seed:dev:mysql": "SERVICE_NAME=cli bun run --env-file=.env.dev scripts/seed.ts mysql",
    "seed:dev:mongo": "SERVICE_NAME=cli bun run --env-file=.env.dev scripts/seed.ts mongo",
    "seed:dev:sqlite": "SERVICE_NAME=cli bun run --env-file=.env.dev scripts/seed.ts sqlite",
    "seed:dev:pg": "SERVICE_NAME=cli bun run --env-file=.env.dev scripts/seed.ts pg",
    "seed:prod": "SERVICE_NAME=cli bun run --env-file=.env.prod scripts/seed.ts",
    "m2m:list:dev": "bun run --env-file=.env.dev scripts/m2m/list.ts",
    "m2m:add:dev": "bun run --env-file=.env.dev scripts/m2m/add.ts",
    "m2m:check:dev": "bun run --env-file=.env.dev scripts/m2m/check.ts",
    "m2m:delete:dev": "bun run --env-file=.env.dev scripts/m2m/delete.ts",
    "m2m:ip:dev": "bun run --env-file=.env.dev scripts/m2m/ip.ts",
    "m2m:logs:dev": "bun run --env-file=.env.dev scripts/m2m/logs.ts",
    "m2m:status:dev": "bun run --env-file=.env.dev scripts/m2m/status.ts",
    "m2m:list:prod": "bun run --env-file=.env.prod scripts/m2m/list.ts",
    "m2m:add:prod": "bun run --env-file=.env.prod scripts/m2m/add.ts",
    "m2m:check:prod": "bun run --env-file=.env.prod scripts/m2m/check.ts",
    "m2m:delete:prod": "bun run --env-file=.env.prod scripts/m2m/delete.ts",
    "m2m:ip:prod": "bun run --env-file=.env.prod scripts/m2m/ip.ts",
    "m2m:logs:prod": "bun run --env-file=.env.prod scripts/m2m/logs.ts",
    "m2m:status:prod": "bun run --env-file=.env.prod scripts/m2m/status.ts",
    "make": "bun run scripts/make.ts",
    "build": "bun build ./src/index.ts --compile --outfile server",
    "dev": "SERVICE_NAME=app bun run --watch --env-file=.env.dev src/index.ts",
    "prod": "SERVICE_NAME=app bun run --env-file=.env.prod src/index.ts",
    "worker:dev": "SERVICE_NAME=queue bun run --env-file=.env.dev src/workers/index.ts",
    "worker:prod": "SERVICE_NAME=queue bun run --env-file=.env.prod src/workers/index.ts",
    "server:bin:dev": "SERVICE_NAME=app env $(cat .env.dev | grep -v '^#' | xargs) ./server",
    "server:bin:prod": "SERVICE_NAME=app env $(cat .env.prod | grep -v '^#' | xargs) ./server",
    "worker:bin:dev": "SERVICE_NAME=queue env $(cat .env.dev | grep -v '^#' | xargs) ./server --worker",
    "worker:bin:prod": "SERVICE_NAME=queue env $(cat .env.prod | grep -v '^#' | xargs) ./server --worker"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.69.3",
    "hono": "^4.6.0",
    "ioredis": "^5.9.3",
    "mongodb": "^7.1.0",
    "mysql2": "^3.12.0",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/ioredis": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.16.0",
    "typescript": "^5.7.0"
  }
}